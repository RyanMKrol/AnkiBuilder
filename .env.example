# AnkiBuilder — local environment template.
# Copy this to `.env` and fill in the values:  cp .env.example .env
#
# `.env` is gitignored and MUST NEVER be committed. The tool reads these from the
# environment only and never writes secrets to disk. The CLI loads `.env` when
# present (via Node's native `--env-file`), so you don't have to export by hand.

# Required for the audio stage (ElevenLabs TTS). Get a key at https://elevenlabs.io.
ELEVENLABS_API_KEY=

# Optional: the ElevenLabs voice id to speak cards with (else chosen per run).
# ELEVENLABS_VOICE_ID=

# Optional: automatic trailing-silence/blip trimming of ElevenLabs clips needs a system
# ffmpeg (brew install ffmpeg). Best-effort — audio still builds without it (clips just
# keep their trailing silence). Set to 0 to disable even when ffmpeg is present.
# ANKI_BUILDER_TRIM_AUDIO=1

# Local library state (audio cache, EPUB registry) lives in .anki-builder/ inside
# this checkout, gitignored — nothing to configure here.
